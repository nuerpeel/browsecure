            with open(path, "a", encoding="utf-8") as f:\
                f.write(content)\
        else:\
            path.write_text(content, encoding="utf-8")\
    except PermissionError:\
        return f"Error: Permission denied: \{path\}"\
    except OSError as e:\
        return f"Error writing file: \{e\}"\
