  --threads 16 \\\
  --batch-size 2048 \\\
  --temp 1.0 \\\
  --top-p 0.95 \\\
  --top-k 40 \\\
  --min-p 0.01 \\\
  --jinja \\\
  --seed 3407\
Restart=always\
RestartSec=10\
\
